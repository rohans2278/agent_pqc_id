# Copy to .env and fill in. .env is gitignored; this file is the contract.

# AWS KMS (operator's master key)
AWS_REGION=us-east-1
KMS_KEY_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only if using temporary credentials

# Postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/pqc

# Google Gemini (agents' LLM)
GOOGLE_API_KEY=

# Where the agent (MCP client) reaches the MCP server
MCP_SERVER_URL=http://localhost:8001/mcp
